# Deterministic cross-platform source bytes. Windows QA and provenance hashes must
# see the same LF-authored text as Linux; runtime/media artefacts remain binary.
* text=auto

*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

*.blend binary
*.glb binary
*.gltf binary
*.ico binary
*.jpeg binary
*.jpg binary
*.mp3 binary
*.ogg binary
*.png binary
*.wav binary
*.webp binary
