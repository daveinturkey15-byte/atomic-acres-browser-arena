{
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "author:blender-arena": "npx vite-node scripts/blender/export-atomic-acres-arena-spec.ts source-assets/blender/atomic-acres-arena-spec.json && PYTHONHASHSEED=0 blender --background --factory-startup --python scripts/blender/create-atomic-acres-blender-arena.py",
    "baseline:generate": "tsx scripts/qa/generate-pass25a-baselines.ts",
    "verify:gameplay-contract": "tsx scripts/qa/generate-pass25a-baselines.ts --check",
    "test": "vitest run",
    "test:property": "vitest run src/gameplay-state-property.test.ts",
    "test:property:nightly": "PASS25_PROPERTY_RUNS=100000 vitest run src/gameplay-state-property.test.ts",
    "test:mutation": "PASS25_PROPERTY_RUNS=50 stryker run",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:bounded": "node scripts/qa/run-bounded-e2e.mjs",
    "qa:release": "node scripts/qa/capture-release.mjs",
    "qa:multiplayer": "node scripts/qa/verify-multiplayer.mjs",
    "qa:pass30:multiplayer": "node scripts/qa/verify-pass30-supports.mjs",
    "qa:pass31:overdrive": "node scripts/qa/verify-pass31-overdrive.mjs",
    "qa:pass33:maps": "node scripts/qa/verify-pass33-maps.mjs",
    "qa:pass33:rays": "node scripts/qa/verify-pass33-ray-matrix.cjs",
    "qa:multiplayer:lifecycle": "node scripts/qa/verify-multiplayer-lifecycle.mjs",
    "qa:network-chaos": "tsx scripts/qa/run-network-chaos-matrix.ts",
    "qa:network-chaos:soak": "tsx scripts/qa/run-network-chaos-soak.ts",
    "qa:environment": "node scripts/qa/capture-pass25a-environment.mjs",
    "qa:pass29:capture": "node scripts/qa/capture-pass29-environment.mjs",
    "qa:pass29:luminance": "python3 scripts/qa/measure-pass29-luminance.py",
    "qa:pass29:verify": "node scripts/qa/run-pass29-environment-verification.mjs",

    "leaderboard:check": "tsc -p worker/tsconfig.json && vitest run worker/src/index.test.ts src/global-leaderboard.test.ts src/high-scores.test.ts",
    "leaderboard:migrate:local": "wrangler d1 migrations apply atomic-acres-leaderboard --local",
    "leaderboard:dev": "wrangler dev --local --port 8787 --var RATE_LIMIT_SALT:local-qa-not-secret",
    "leaderboard:deploy": "wrangler d1 migrations apply atomic-acres-leaderboard --remote && wrangler deploy",
    "qa:soak": "node scripts/qa/run-pass25a-soak.mjs",
    "audit:dependencies": "npm audit --omit=dev",
    "verify:release-tree": "node scripts/qa/verify-release-tree.mjs",
    "lint": "tsc --noEmit",
    "verify:pass25a:core": "npm run lint && npm run verify:gameplay-contract && npm test && npm run build && npm run verify:release-tree && npm run audit:dependencies",
    "verify:pass25a": "node scripts/qa/run-pass25a-verification.mjs",
    "verify": "npm run lint && npm run verify:gameplay-contract && npm test && npm run build && npm run verify:release-tree && npm run audit:dependencies && npm run test:e2e",
    "deploy": "npm run build && gh-pages -d dist --add"
  },
  "overrides": {
    "typed-rest-client": {
      "qs": "6.15.3"
    }
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.19.3",
    "peerjs": "1.5.5",
    "three": "0.185.1",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260718.1",
    "@playwright/test": "1.61.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "26.1.1",
    "@types/three": "0.185.0",
    "fast-check": "4.9.0",
    "gh-pages": "6.3.0",
    "peer": "1.0.2",
    "tsx": "4.23.1",
    "vitest": "4.1.9",
    "wrangler": "^4.112.0"
  },
  "name": "atomic-acres-browser-arena",
  "version": "1.0.0",
  "description": "Original retro-future browser arena FPS with peer-to-peer multiplayer",
  "private": "true"
}
